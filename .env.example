DATABASE_URL=mysql://root:root@localhost:3306/judge_ai
JWT_SECRET=replace-with-at-least-32-random-characters
# Optional. Separate secret for encrypting stored provider API keys.
# If empty, JWT_SECRET is used as a fallback (keeps existing encrypted keys readable).
# Set to a distinct 32+ char value so rotating JWT_SECRET does not invalidate stored keys.
PROVIDER_ENCRYPTION_SECRET=
OWNER_OPEN_ID=desktop-local-user

# Keep runtime files outside the source checkout when possible.
# Example Windows path:
# JUDGE_AI_DATA_DIR=C:\JudgeAI\data
JUDGE_AI_DATA_DIR=
JUDGE_AI_UPLOADS_DIR=
JUDGE_AI_LOG_DIR=

# Optional startup provider seeding. Leave empty and configure providers in-app.
DEEPSEEK_API_KEY=
KIMI_API_KEY=

# Optional. Set to 1 to enable the Vite debug-collector plugin (writes browser
# console/network/session logs to .manus-logs/ during dev). Off by default.
JUDGE_AI_DEBUG_COLLECTOR=
